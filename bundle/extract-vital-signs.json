{
    "resourceType": "Questionnaire",
    "id": "extract-vital-signs",
    "name": "extract-vital-signs",
    "title": "Extract Vital Signs",
    "description": "Demonstrates vital-sign extraction for body temperature with hidden derived data used by mapping.",
    "status": "active",
    "subjectType": [
        "Patient"
    ],
    "url": "http://example.org/fhir/Questionnaire/extract-vital-signs",
    "meta": {
        "profile": [
            "https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"
        ]
    },
    "item": [
        {
            "linkId": "patientId",
            "text": "PatientId",
            "extension": [
                {
                    "valueBoolean": true,
                    "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"
                },
                {
                    "valueExpression": {
                        "language": "text/fhirpath",
                        "expression": "%Patient.id"
                    },
                    "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"
                }
            ],
            "type": "string"
        },
        {
            "linkId": "instructions",
            "text": "Instructions: Enter Body temperature and submit the questionnaire. The mapping creates an Observation (LOINC 8310-5, vital-signs category). Hidden calculated field temp-severity-hidden is included for extraction/mapping use.",
            "type": "display"
        },
        {
            "linkId": "body-temperature",
            "text": "Body temperature",
            "required": true,
            "code": [
                {
                    "system": "http://loinc.org",
                    "code": "8310-5",
                    "display": "Body temperature"
                }
            ],
            "extension": [
                {
                    "valueCoding": {
                        "code": "Cel",
                        "system": "http://unitsofmeasure.org",
                        "display": "C"
                    },
                    "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-unitOption"
                }
            ],
            "type": "quantity"
        },
        {
            "linkId": "temp-severity-hidden",
            "text": "Temperature severity (hidden)",
            "extension": [
                {
                    "valueBoolean": true,
                    "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"
                },
                {
                    "valueExpression": {
                        "language": "text/fhirpath",
                        "expression": "iif(\n  %resource.repeat(item).where(linkId='body-temperature').answer.valueQuantity.value.exists(),\n  iif(\n    %resource.repeat(item).where(linkId='body-temperature').answer.valueQuantity.value.first() >= 38,\n    'fever',\n    'normal'\n  ),\n  ''\n)"
                    },
                    "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"
                }
            ],
            "type": "string"
        }
    ],
    "extension": [
        {
            "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-launchContext",
            "extension": [
                {
                    "url": "name",
                    "valueCoding": {
                        "code": "Patient"
                    }
                },
                {
                    "url": "type",
                    "valueCode": "Patient"
                }
            ]
        }
    ]
}