{
    "resourceType": "Questionnaire",
    "id": "launch-context",
    "name": "launch-context",
    "title": "Launch Context",
    "status": "active",
    "url": "http://example.org/fhir/Questionnaire/launch-context",
    "meta": {
        "profile": [
            "https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"
        ]
    },
    "item": [
        {
            "linkId": "instructions",
            "text": "Instructions: Open this form in Patient context. Patient ID and full name are prefilled from %patient launch context.",
            "type": "display"
        },
        {
            "linkId": "patient-id",
            "text": "Patient ID from launchContext",
            "readOnly": true,
            "extension": [
                {
                    "valueExpression": {
                        "language": "text/fhirpath",
                        "expression": "%patient.id.first()"
                    },
                    "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"
                }
            ],
            "type": "string"
        },
        {
            "linkId": "patient-name",
            "text": "Patient name from launchContext",
            "readOnly": true,
            "extension": [
                {
                    "valueExpression": {
                        "language": "text/fhirpath",
                        "expression": "%patient.name.first().given.first() + ' ' + %patient.name.first().family"
                    },
                    "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"
                }
            ],
            "type": "string"
        }
    ],
    "extension": [
        {
            "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-launchContext",
            "extension": [
                {
                    "url": "name",
                    "valueCoding": {
                        "system": "http://hl7.org/fhir/uv/sdc/CodeSystem/launchContext",
                        "code": "patient"
                    }
                },
                {
                    "url": "type",
                    "valueCode": "Patient"
                }
            ]
        }
    ]
}