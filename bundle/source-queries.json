{
    "resourceType": "Questionnaire",
    "id": "source-queries",
    "name": "source-queries",
    "title": "Source Queries",
    "status": "active",
    "url": "http://example.org/fhir/Questionnaire/source-queries",
    "meta": {
        "profile": [
            "https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"
        ]
    },
    "contained": [
        {
            "resourceType": "Bundle",
            "id": "ConditionBundle",
            "type": "batch",
            "entry": [
                {
                    "request": {
                        "method": "GET",
                        "url": "/Condition?patient=Patient/{{ %patient.id }}&_sort=-recorded-date&_count=200"
                    }
                }
            ]
        }
    ],
    "item": [
        {
            "linkId": "conditions-summary",
            "text": "Conditions",
            "readOnly": true,
            "extension": [
                {
                    "valueExpression": {
                        "language": "text/fhirpath",
                        "expression": "%ConditionBundle.entry.resource.entry.resource .select('Name: ' & (code.coding.first().display | code.text).first()) .join('\\n')"
                    },
                    "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"
                }
            ],
            "type": "text"
        }
    ],
    "extension": [
        {
            "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-launchContext",
            "extension": [
                {
                    "url": "name",
                    "valueCoding": {
                        "system": "http://hl7.org/fhir/uv/sdc/CodeSystem/launchContext",
                        "code": "patient"
                    }
                },
                {
                    "url": "type",
                    "valueCode": "Patient"
                }
            ]
        },
        {
            "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-sourceQueries",
            "valueReference": {
                "reference": "#ConditionBundle"
            }
        }
    ]
}