 "http://hl7.org/fhir/StructureDefinition/entryFormat"}, {"valueExpression": {"language": "text/fhirpath", "expression": "%Patient.telecom.where(system='email').value.first()"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "string"}, {"linkId": "patient-ssn", "text": "SSN", "readOnly": true, "extension": [{"valueString": "SSN", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}, {"valueExpression": {"language": "text/fhirpath", "expression": "%Patient.identifier.where(system='http://hl7.org/fhir/sid/us-ssn').value.first()"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "string"}], "extension": [{"url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-launchContext", "extension": [{"url": "name", "valueCoding": {"code": "Patient"}}, {"url": "type", "valueCode": "Patient"}]}]}}, {"fullUrl": "urn:uuid:Questionnaire:assemble", "request": {"method": "PUT", "url": "/Questionnaire/assemble"}, "resource": {"resourceType": "Questionnaire", "id": "assemble", "name": "assemble", "title": "Assemble", "description": "Demonstrates modular form composition via `subQuestionnaire`.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/assemble", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: This form embeds two existing conference questionnaires via subQuestionnaire (nested-groups and read-only). Resolve each canonical id to the Questionnaire resource in your environment.", "type": "display"}, {"linkId": "demo-nested-groups-group", "text": "A. Nested groups (embedded)", "type": "group", "item": [{"linkId": "demo-nested-groups-embed", "extension": [{"valueCanonical": "nested-groups", "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-subQuestionnaire"}], "type": "display"}]}, {"linkId": "demo-read-only-group", "text": "B. Read-only (embedded)", "type": "group", "item": [{"linkId": "demo-read-only-embed", "extension": [{"valueCanonical": "read-only", "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-subQuestionnaire"}], "type": "display"}]}]}}, {"fullUrl": "urn:uuid:Questionnaire:reference-answer-expression", "request": {"method": "PUT", "url": "/Questionnaire/reference-answer-expression"}, "resource": {"resourceType": "Questionnaire", "id": "reference-answer-expression", "name": "reference-answer-expression", "title": "Reference with answerExpression", "description": "Demonstrates `type: reference` with `answerExpression` query and `choiceColumn` display formatting.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/reference-answer-expression", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: Use the reference picker to select a Practitioner loaded by `answerExpression`; displayed options are formatted by `choiceColumn`.", "type": "display"}, {"linkId": "attending-practitioner", "text": "Attending practitioner", "extension": [{"url": "http://hl7.org/fhir/StructureDefinition/questionnaire-referenceResource", "valueCode": "Practitioner"}, {"url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-choiceColumn", "extension": [{"url": "forDisplay", "valueBoolean": true}, {"url": "path", "valueString": "name.given.first() + ' ' + name.family"}]}, {"valueExpression": {"language": "application/x-fhir-query", "expression": "Practitioner"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-answerExpression"}], "type": "reference"}]}}, {"fullUrl": "urn:uuid:Questionnaire:hidden-fields", "request": {"method": "PUT", "url": "/Questionnaire/hidden-fields"}, "resource": {"resourceType": "Questionnaire", "id": "hidden-fields", "name": "hidden-fields", "title": "Hidden Fields", "description": "Demonstrates hidden calculated fields: visible pulse input, hidden derived severity, and visible severity summary.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/hidden-fields", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: Enter pulse values to test hidden calculated field behavior: below 60 -> Critical low, 60-110 -> Normal, above 110 -> High. Clear the pulse input to confirm the summary shows Severity: \u2014.", "type": "display"}, {"linkId": "pulse", "text": "Pulse", "extension": [{"valueString": "Enter a value between 60 and 260", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "integer"}, {"linkId": "severity", "text": "Derived severity", "extension": [{"valueBoolean": true, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"}, {"valueExpression": {"language": "text/fhirpath", "expression": "iif(\n  %resource.repeat(item).where(linkId='pulse').answer.valueInteger.exists() and\n  %resource.repeat(item).where(linkId='pulse').answer.valueInteger.first() >= 1,\n  iif(\n    %resource.repeat(item).where(linkId='pulse').answer.valueInteger.first() > 110,\n    'High',\n    iif(\n      %resource.repeat(item).where(linkId='pulse').answer.valueInteger.first() < 60,\n      'Critical low',\n      'Normal'\n    )\n  ),\n  ''\n)"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"}], "type": "string"}, {"linkId": "severity-view", "text": "Severity", "readOnly": true, "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "iif(\n  %resource.repeat(item).where(linkId='pulse').answer.valueInteger.exists() and\n  %resource.repeat(item).where(linkId='pulse').answer.valueInteger.first() >= 1,\n  iif(\n    %resource.repeat(item).where(linkId='pulse').answer.valueInteger.first() > 110,\n    'High',\n    iif(\n      %resource.repeat(item).where(linkId='pulse').answer.valueInteger.first() < 60,\n      'Critical low',\n      'Normal'\n    )\n  ),\n  '\u2014'\n)"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"}], "type": "string"}]}}, {"fullUrl": "urn:uuid:Questionnaire:variables", "request": {"method": "PUT", "url": "/Questionnaire/variables"}, "resource": {"resourceType": "Questionnaire", "id": "variables", "name": "variables", "title": "Variables", "description": "Demonstrates SDC `variable` on a parent group. Child items reuse `%PulseVal`, `%PulseBand`, and `%PulseDouble` in calculated and display expressions.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/variables", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: Enter pulse (bpm) >= 1. Summary shows band-specific guidance and doubled value; Result and Doubled mirror %PulseBand and %PulseDouble.", "type": "display"}, {"linkId": "variable-demo-group", "text": "Derived values via parent variables", "extension": [{"valueExpression": {"name": "PulseVal", "language": "text/fhirpath", "expression": "%resource.repeat(item).where(linkId='var-pulse').answer.valueInteger.first()"}, "url": "http://hl7.org/fhir/StructureDefinition/variable"}, {"valueExpression": {"name": "PulseBand", "language": "text/fhirpath", "expression": "iif(\n  %PulseVal.exists() and %PulseVal >= 1,\n  iif(\n    %PulseVal > 110,\n    'High',\n    iif(%PulseVal < 60, 'Critical low', 'Normal')\n  ),\n  ''\n)"}, "url": "http://hl7.org/fhir/StructureDefinition/variable"}, {"valueExpression": {"name": "PulseDouble", "language": "text/fhirpath", "expression": "iif(%PulseVal.exists() and %PulseVal >= 1, %PulseVal * 2, 0)"}, "url": "http://hl7.org/fhir/StructureDefinition/variable"}], "type": "group", "item": [{"linkId": "var-pulse", "text": "Pulse (bpm)", "extension": [{"valueString": "Enter a pulse rate (bpm) of 1 or greater", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "integer"}, {"linkId": "variables-summary", "text": "Banded guidance", "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "iif(\n  %PulseVal.exists() and %PulseVal >= 1,\n  iif(\n    %PulseVal > 110,\n    'Elevated pulse. Initiate appropriate clinical care. Inform the midwife / nurse in charge if escalation is required. Doubled value: ' & ((%PulseVal * 2).toString()),\n    iif(\n      %PulseVal < 60,\n      'Low pulse. Repeat observations as indicated. Consult promptly with the midwife / nurse in charge to determine if further review is needed. Doubled value: ' & ((%PulseVal * 2).toString()),\n      'Pulse within range. Continue routine monitoring. Band: Normal. Doubled value: ' & ((%PulseVal * 2).toString()) & '.'\n    )\n  ),\n  'No pulse entered. Enter a pulse (bpm) of 1 or greater to display guidance.'\n)"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"}], "type": "text"}, {"linkId": "band-echo", "text": "Result (PulseBand)", "readOnly": true, "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "%PulseBand"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"}], "type": "string"}, {"linkId": "double-echo", "text": "Doubled (PulseDouble variable)", "readOnly": true, "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "iif(%PulseVal.exists() and %PulseVal >= 1, (%PulseVal * 2).toString(), '')"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"}], "type": "string"}]}]}}]}