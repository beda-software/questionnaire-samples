{"resourceType": "Bundle", "type": "transaction", "entry": [{"fullUrl": "urn:uuid:Questionnaire:extract-vital-signs", "request": {"method": "PUT", "url": "/Questionnaire/extract-vital-signs"}, "resource": {"resourceType": "Questionnaire", "id": "extract-vital-signs", "name": "extract-vital-signs", "title": "Extract Vital Signs", "description": "Demonstrates vital-sign extraction for body temperature with hidden derived data used by mapping.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/extract-vital-signs", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "patientId", "text": "PatientId", "extension": [{"valueBoolean": true, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"}, {"valueExpression": {"language": "text/fhirpath", "expression": "%Patient.id"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "string"}, {"linkId": "instructions", "text": "Instructions: Enter Body temperature and submit the questionnaire. The mapping creates an Observation (LOINC 8310-5, vital-signs category). Hidden calculated field temp-severity-hidden is included for extraction/mapping use.", "type": "display"}, {"linkId": "body-temperature", "text": "Body temperature", "required": true, "code": [{"system": "http://loinc.org", "code": "8310-5", "display": "Body temperature"}], "extension": [{"valueCoding": {"code": "Cel", "system": "http://unitsofmeasure.org", "display": "C"}, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-unitOption"}], "type": "quantity"}, {"linkId": "temp-severity-hidden", "text": "Temperature severity (hidden)", "extension": [{"valueBoolean": true, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"}, {"valueExpression": {"language": "text/fhirpath", "expression": "iif(\n  %resource.repeat(item).where(linkId='body-temperature').answer.valueQuantity.value.exists(),\n  iif(\n    %resource.repeat(item).where(linkId='body-temperature').answer.valueQuantity.value.first() >= 38,\n    'fever',\n    'normal'\n  ),\n  ''\n)"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"}], "type": "string"}], "extension": [{"url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-launchContext", "extension": [{"url": "name", "valueCoding": {"code": "Patient"}}, {"url": "type", "valueCode": "Patient"}]}]}}, {"fullUrl": "urn:uuid:Questionnaire:enable-when-options", "request": {"method": "PUT", "url": "/Questionnaire/enable-when-options"}, "resource": {"resourceType": "Questionnaire", "id": "enable-when-options", "name": "enable-when-options", "title": "EnableWhen Options", "description": "Demonstrates visibility rules with `enableWhen`, `enableBehavior` (`any`/`all`), `enableWhenExpression`, parent variables, and `operator: exists`.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/enable-when-options", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: Set Any allergies? and Follow-up visit needed? to test classic enableWhen, enableWhenExpression, and enableBehavior (any / all). Then enter any text in Chief complaint to trigger the operator: exists example.", "type": "display"}, {"linkId": "has-allergy", "text": "Any allergies?", "type": "choice", "answerOption": [{"valueCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "N", "display": "No"}}, {"valueCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}]}, {"linkId": "follow-up-needed", "text": "Follow-up visit needed?", "type": "choice", "answerOption": [{"valueCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "N", "display": "No"}}, {"valueCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}]}, {"linkId": "allergy-details-classic", "text": "Allergy details (classic enableWhen)", "type": "text", "enableWhen": [{"question": "has-allergy", "operator": "=", "answerCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}]}, {"linkId": "allergy-details-expression", "text": "Allergy details (enableWhenExpression)", "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "iif(\n  %resource.repeat(item).where(linkId='has-allergy').answer.valueCoding.where(code='Y').exists(),\n  true,\n  false\n)"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-enableWhenExpression"}], "type": "text"}, {"linkId": "contact-preference-any", "text": "Contact preference (shown if allergy Yes OR follow-up Yes)", "type": "text", "enableBehavior": "any", "enableWhen": [{"question": "has-allergy", "operator": "=", "answerCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}, {"question": "follow-up-needed", "operator": "=", "answerCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}]}, {"linkId": "schedule-deep-review-all", "text": "Schedule deep review (only when allergy Yes AND follow-up Yes)", "type": "text", "enableBehavior": "all", "enableWhen": [{"question": "has-allergy", "operator": "=", "answerCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}, {"question": "follow-up-needed", "operator": "=", "answerCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}]}, {"linkId": "allergy-extra-group", "text": "Extra allergy block (group-level enableWhen)", "type": "group", "enableWhen": [{"question": "has-allergy", "operator": "=", "answerCoding": {"system": "http://terminology.hl7.org/CodeSystem/v2-0136", "code": "Y", "display": "Yes"}}], "item": [{"linkId": "reaction-note", "text": "Reaction / severity notes", "type": "text"}, {"linkId": "last-episode-date", "text": "Last episode date", "type": "date"}]}, {"linkId": "variable-demo-group", "text": "Expression using parent variable %AllergyYes", "extension": [{"valueExpression": {"name": "AllergyYes", "language": "text/fhirpath", "expression": "iif(\n  %resource.repeat(item).where(linkId='has-allergy').answer.valueCoding.where(code='Y').exists(),\n  true,\n  false\n)"}, "url": "http://hl7.org/fhir/StructureDefinition/variable"}], "type": "group", "item": [{"linkId": "details-with-variable", "text": "Enabled via %AllergyYes (same logic as allergy-details-expression)", "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "iif(%AllergyYes = true, true, false)"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-enableWhenExpression"}], "type": "text"}]}, {"linkId": "chief-complaint-free", "text": "Chief complaint (Enter any text here to show the Detail field below)", "type": "string"}, {"linkId": "chief-complaint-detail-exists", "text": "Detail (appears after you type something above)", "type": "text", "enableWhen": [{"question": "chief-complaint-free", "operator": "exists", "answerBoolean": true}]}]}}, {"fullUrl": "urn:uuid:Questionnaire:choice-initial-expression", "request": {"method": "PUT", "url": "/Questionnaire/choice-initial-expression"}, "resource": {"resourceType": "Questionnaire", "id": "choice-initial-expression", "name": "choice-initial-expression", "title": "Choice InitialExpression", "description": "Demonstrates two choice initialization patterns:  Preferred contact type uses local `answerOption` and chooses phone/email from Patient.telecom. Preferred language uses external `answerValueSet` and initializes from Patient.communication.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/choice-initial-expression", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "patientId", "text": "PatientId", "extension": [{"valueBoolean": true, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"}, {"valueExpression": {"language": "text/fhirpath", "expression": "%Patient.id"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "string"}, {"linkId": "instructions", "text": "Instructions: This form shows two choice initialization patterns. Preferred contact type uses local `answerOption` (phone/email from Patient.telecom). Preferred language uses external `answerValueSet` (from Patient.communication).", "type": "display"}, {"linkId": "answer-option-section", "text": "Choice with answerOption + initialExpression", "type": "group", "item": [{"linkId": "preferred-contact-type", "text": "Preferred contact type", "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "%Questionnaire.repeat(item).where(linkId='preferred-contact-type').answerOption.valueCoding.where(\n  code=iif(\n    %Patient.telecom.where(system='phone').exists(),\n    'phone',\n    'email'\n  )\n)"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "choice", "answerOption": [{"valueCoding": {"system": "http://example.org/fhir/CodeSystem/contact-type", "code": "phone", "display": "Phone"}}, {"valueCoding": {"system": "http://example.org/fhir/CodeSystem/contact-type", "code": "email", "display": "Email"}}]}]}, {"linkId": "answer-valueset-section", "text": "Choice with answerValueSet + initialExpression", "type": "group", "item": [{"linkId": "preferred-language", "text": "Preferred language", "answerValueSet": "http://hl7.org/fhir/ValueSet/all-languages", "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "%Patient.communication.where(preferred=true).language.coding"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "choice"}]}], "extension": [{"url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-launchContext", "extension": [{"url": "name", "valueCoding": {"code": "Patient"}}, {"url": "type", "valueCode": "Patient"}]}]}}, {"fullUrl": "urn:uuid:Questionnaire:nested-groups", "request": {"method": "PUT", "url": "/Questionnaire/nested-groups"}, "resource": {"resourceType": "Questionnaire", "id": "nested-groups", "name": "nested-groups", "title": "Nested Questionnaire.item.item", "description": "Demonstrates nested `Questionnaire.item.item` hierarchy, including a repeating subgroup.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/nested-groups", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: Fill the nested fields under General section, then add one or more rows under Medications to verify repeating subgroup behavior.", "type": "display"}, {"linkId": "assessment-root", "text": "Assessment root group", "type": "group", "item": [{"linkId": "general-section", "text": "General section", "type": "group", "item": [{"linkId": "chief-complaint", "text": "Chief complaint", "extension": [{"valueString": "Enter the patient's chief complaint", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "text"}, {"linkId": "onset-date", "text": "Onset date", "type": "date"}]}, {"linkId": "medications-section", "text": "Medications (repeating subgroup)", "repeats": true, "type": "group", "item": [{"linkId": "medication-name", "text": "Medication name", "extension": [{"valueString": "Enter the medication name", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "string"}, {"linkId": "medication-dose", "text": "Dose", "extension": [{"valueString": "Enter the medication dose", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "string"}]}]}]}}, {"fullUrl": "urn:uuid:Questionnaire:item-constraint", "request": {"method": "PUT", "url": "/Questionnaire/item-constraint"}, "resource": {"resourceType": "Questionnaire", "id": "item-constraint", "name": "item-constraint", "title": "Item Constraint", "description": "Demonstrates `itemConstraint` with two fields where one field is mandatory.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/item-constraint", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: This form has two fields. Primary contact is mandatory. If Secondary contact is provided, it must differ from Primary contact.", "type": "display"}, {"linkId": "primary-contact", "text": "Primary contact", "required": true, "extension": [{"valueString": "Enter primary contact value", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "string"}, {"linkId": "secondary-contact", "text": "Secondary contact", "extension": [{"valueString": "Optional; must differ from primary contact", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}, {"url": "http://hl7.org/fhir/StructureDefinition/questionnaire-constraint", "extension": [{"url": "key", "valueId": "secondary-not-equal-primary"}, {"url": "requirements", "valueString": "Secondary contact, if present, must not duplicate primary contact"}, {"url": "severity", "valueCode": "error"}, {"url": "human", "valueString": "Secondary contact must be different from primary contact"}, {"url": "expression", "valueString": "%QuestionnaireResponse.item.where(linkId='secondary-contact').answer.empty() or %QuestionnaireResponse.item.where(linkId='secondary-contact').answer.first() != %QuestionnaireResponse.item.where(linkId='primary-contact').answer.first()"}]}], "type": "string"}]}}, {"fullUrl": "urn:uuid:Questionnaire:repeats-true-group", "request": {"method": "PUT", "url": "/Questionnaire/repeats-true-group"}, "resource": {"resourceType": "Questionnaire", "id": "repeats-true-group", "name": "repeats-true-group", "title": "Repeats Structure for Group", "description": "Demonstrates repeatable group structure (`repeats: true`) for procedure rows.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/repeats-true-group", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: Add one or more procedure rows and fill date, name, result, and notes.", "type": "display"}, {"linkId": "procedures", "text": "Procedures", "repeats": true, "type": "group", "item": [{"linkId": "procedure-date", "text": "Date", "extension": [{"valueString": "Enter the procedure date", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}, {"valueExpression": {"language": "text/fhirpath", "expression": "iif(%context.answer.exists(), %context.answer.valueDateTime, now())"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression"}], "type": "date"}, {"linkId": "procedure-name", "text": "Name", "extension": [{"valueString": "Enter the procedure name", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "string"}, {"linkId": "procedure-result", "text": "Result", "extension": [{"valueString": "Enter the procedure result", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "string"}, {"linkId": "procedure-notes", "text": "Notes", "extension": [{"valueCodeableConcept": {"coding": [{"code": "markdown-editor"}]}, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl"}, {"valueString": "Enter the procedure notes", "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"}], "type": "string"}]}]}}, {"fullUrl": "urn:uuid:Questionnaire:source-square", "request": {"method": "PUT", "url": "/Questionnaire/source-square"}, "resource": {"resourceType": "Questionnaire", "id": "source-square", "name": "source-square", "title": "Source Square", "description": "Demonstrates `sourceQueries` with a contained batch Bundle and rendering fetched Condition data into a read-only summary field.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/source-square", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "contained": [{"resourceType": "Bundle", "id": "ConditionBundle", "type": "batch", "entry": [{"request": {"method": "GET", "url": "/Condition?patient=Patient/{{ %Patient.id }}&_sort=-recorded-date&_count=200"}}]}], "item": [{"linkId": "patientId", "text": "PatientId", "extension": [{"valueBoolean": true, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"}, {"valueExpression": {"language": "text/fhirpath", "expression": "%Patient.id"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "string"}, {"linkId": "instructions", "text": "Instructions: This form shows the source square pattern. The conditions are displayed in the Conditions field.", "type": "display"}, {"linkId": "conditions-summary", "text": "Conditions", "readOnly": true, "extension": [{"valueExpression": {"language": "text/fhirpath", "expression": "%ConditionBundle.entry.resource.entry.resource .select(\n  'Name: ' &\n  iif(\n    code.coding.first().display.exists(),\n    code.coding.first().display,\n    iif(\n      code.text.exists(),\n      code.text,\n      code.coding.code.first()\n    )\n  ) &\n  '\\n' &\n  'Data: ' &\n  iif(\n    recordedDate.exists(),\n    recordedDate.toString(),\n    iif(\n      onsetDateTime.exists(),\n      onsetDateTime.toString(),\n      ''\n    )\n  )\n) .join('\\n\\n')"}, "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression"}], "type": "text"}], "extension": [{"url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-launchContext", "extension": [{"url": "name", "valueCoding": {"code": "Patient"}}, {"url": "type", "valueCode": "Patient"}]}, {"url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-sourceQueries", "valueReference": {"reference": "#ConditionBundle"}}]}}, {"fullUrl": "urn:uuid:Questionnaire:read-only", "request": {"method": "PUT", "url": "/Questionnaire/read-only"}, "resource": {"resourceType": "Questionnaire", "id": "read-only", "name": "read-only", "title": "ReadOnly", "description": "Demonstrates static read-only behavior using `readOnly: true`.", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/read-only", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "instructions", "text": "Instructions: Compare two fields below. Read-only field cannot be edited, editable field can be changed.", "type": "display"}, {"linkId": "read-only-note", "text": "Read-only note", "readOnly": true, "type": "string"}, {"linkId": "editable-note", "text": "Editable note", "type": "string"}]}}, {"fullUrl": "urn:uuid:Questionnaire:initial-expression", "request": {"method": "PUT", "url": "/Questionnaire/initial-expression"}, "resource": {"resourceType": "Questionnaire", "id": "initial-expression", "name": "initial-expression", "title": "InitialExpression", "description": "Demonstrates `initialExpression` pre-population from launch context `Patient` (name, gender, birth date, telecom, and SSN).", "status": "active", "subjectType": ["Patient"], "url": "http://example.org/fhir/Questionnaire/initial-expression", "meta": {"profile": ["https://emr-core.beda.software/StructureDefinition/fhir-emr-questionnaire"]}, "item": [{"linkId": "patientId", "text": "PatientId", "extension": [{"valueBoolean": true, "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"}, {"valueExpression": {"language": "text/fhirpath", "expression": "%Patient.i