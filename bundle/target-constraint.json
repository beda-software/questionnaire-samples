                    "url": "http://hl7.org/fhir/StructureDefinition/targetConstraint",
                    "extension": [
                        {
                            "url": "key",
                            "valueId": "secondary-not-equal-primary"
                        },
                        {
                            "url": "requirements",
                            "valueString": "Secondary contact, if present, must not duplicate primary contact"
                        },
                        {
                            "url": "severity",
                            "valueCode": "error"
                        },
                        {
                            "url": "human",
                            "valueString": "Secondary contact must be different from primary contact"
                        },
                        {
                            "url": "expression",
                            "valueString": "%resource.item.where(linkId='secondary-contact').answer.empty() or %resource.item.where(linkId='secondary-contact').answer.first() != %resource.item.where(linkId='primary-contact').answer.first()"
                        }
                    ]
                },
                {
                    "valueString": "Optional; must differ from primary contact",
                    "url": "http://hl7.org/fhir/StructureDefinition/entryFormat"
                }
            ],
            "type": "string"
